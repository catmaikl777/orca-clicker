{
  "name": "orca-clicker",
  "public": true,
  "buildCommand": "npm run build",
  "outputDirectory": "./",
  "routes": [
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
